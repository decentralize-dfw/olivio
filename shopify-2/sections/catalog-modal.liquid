{% comment %}
  Catalog Modal Section — Product detail modal with image carousel,
  color/lens selectors, tabs, recommendations, and CTA buttons.
{% endcomment %}

<!-- ── Modal ──────────────────────────────────────── -->
<div id="modal-overlay" role="dialog" aria-modal="true">
  <div id="modal-backdrop"></div>
  <div id="modal">
    <button id="modal-close" aria-label="{{ 'catalog.modal.close' | t | default: 'Close' }}">✕</button>
    <div id="modal-body">
      <div id="modal-left">
        <div id="modal-main-img-wrap">
          <img id="modal-main-img" src="" alt="" class="img-cover">
        </div>
        <div id="modal-carousel"></div>
      </div>
      <div id="modal-right">
        <!-- Title + price + badges -->
        <div class="modal-sec">
          <div id="modal-title"></div>
          <div class="product-badges" id="modal-badges"></div>
          <div id="modal-price" style="margin-top:6px"></div>
        </div>
        <!-- Color swatches (image-based) -->
        <div class="modal-sec" id="color-section">
          <div class="color-lbl">{{ 'catalog.modal.colors' | t | default: 'Colors' }}</div>
          <div id="color-selector"></div>
        </div>
        <!-- Lens selector -->
        <div class="modal-sec" id="lens-section" style="display:none">
          <div class="lens-lbl">{{ 'catalog.modal.lens' | t | default: 'Lens' }}</div>
          <div id="lens-selector"></div>
        </div>
        <!-- Meta info -->
        <div class="modal-sec" id="meta-section">
          <div class="info-group" id="modal-meta"></div>
        </div>
        <!-- Tabs: Description / Materials / Dimensions / Shipping -->
        <div class="modal-sec" id="tabs-section" style="padding:0; border-bottom:1px solid #eee;">
          <div id="tab-bar"></div>
          <div id="tab-content"></div>
        </div>
        <!-- Recommendations -->
        <div class="modal-sec" id="reco-section" style="display:none">
          <div class="reco-lbl">{{ 'catalog.modal.you_may_also_like' | t | default: 'You may also like' }}</div>
          <div id="reco-scroll"></div>
        </div>
        <!-- CTA Buttons -->
        <div class="modal-sec">
          <div class="modal-cta-row">
            <a id="modal-add-cart" href="#" target="_blank" rel="noopener" class="btn-add-cart">{{ 'catalog.modal.add_to_cart' | t | default: 'Add to Cart' }}</a>
            <a id="modal-buy-now" href="#" target="_blank" rel="noopener" class="btn-buy-now">{{ 'catalog.modal.buy_now' | t | default: 'Buy Now →' }}</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Catalog Product Modal",
  "settings": []
}
{% endschema %}
