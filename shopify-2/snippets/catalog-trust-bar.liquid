{% comment %}
  Trust signals bar — SEO trust badges displayed at the top of the catalog page.
{% endcomment %}

<!-- SEO: Trust signals bar -->
<div id="trust-bar" aria-hidden="true">
  <span>✓ {{ 'catalog.trust.uv400' | t | default: '100% UV400 Protection' }}</span>
  <span>✓ {{ 'catalog.trust.shipping' | t | default: 'Free Shipping €69+' }}</span>
  <span>✓ {{ 'catalog.trust.bpa_free' | t | default: 'BPA-Free Frames' }}</span>
  <span>✓ {{ 'catalog.trust.sizing' | t | default: 'Baby to Teen Sizing' }}</span>
  <span>✓ {{ 'catalog.trust.europe' | t | default: 'Ships Across Europe' }}</span>
</div>
