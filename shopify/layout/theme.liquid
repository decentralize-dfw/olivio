<!DOCTYPE html>
<html lang="{{ request.locale.iso_code | default: 'en' }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, minimum-scale=1.0, maximum-scale=5.0">
  <title>{% if page_title %}{{ page_title }} | {% endif %}Kids Sunglasses &amp; UV400 Eyewear | Olivio&amp;Co</title>

  <!-- SEO: Primary Meta Tags -->
  <meta name="description" content="{% if page_description %}{{ page_description }}{% else %}Buy kids sunglasses with 100% UV400 protection. Toddler, Junior &amp; Teen eyewear — polarised lenses, ski goggles &amp; screen glasses. Interactive catalog. Free EU shipping over €69. Shop Olivio&amp;Co.{% endif %}">
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1">
  <meta name="author" content="Olivio&amp;Co">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta http-equiv="Content-Language" content="en">
  <meta name="theme-color" content="#ffffff">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Olivio&amp;Co">
  <meta name="format-detection" content="telephone=no">

  <!-- SEO: Canonical & Alternate Languages -->
  <link rel="canonical" href="https://olivioandco.eu/products/catalog">
  <link rel="alternate" hreflang="x-default" href="https://olivioandco.eu/products/catalog">
  <link rel="alternate" hreflang="en" href="https://olivioandco.eu/products/catalog">
  <link rel="alternate" hreflang="fr" href="https://olivioandco.eu/fr/products/catalog">

  <!-- SEO: Favicon & Brand Assets -->
  <link rel="icon" type="image/png" href="//olivioandco.eu/cdn/shop/files/1654081682-favicon-_2.png?crop=center&height=32&v=1692099300&width=32">
  <link rel="apple-touch-icon" href="//olivioandco.eu/cdn/shop/files/1654081682-favicon-_2.png?crop=center&height=180&v=1692099300&width=180">

  <!-- SEO: Open Graph (Social Sharing) -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://olivioandco.eu/products/catalog">
  <meta property="og:title" content="Buy Kids Sunglasses with UV400 Protection | Olivio&amp;Co">
  <meta property="og:description" content="Shop toddler, junior &amp; teen sunglasses with 100% UV400 protection. Polarised lenses, ski goggles &amp; screen glasses. Free EU shipping over €69.">
  <meta property="og:image" content="https://olivioandco.eu/cdn/shop/files/catalog-og-image.jpg?width=1200&height=630">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:site_name" content="Olivio&amp;Co Store">
  <meta property="og:locale" content="en_US">
  <meta property="og:locale:alternate" content="fr_FR">

  <!-- SEO: Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Kids Sunglasses UV400 | Toddler to Teen | Olivio&amp;Co">
  <meta name="twitter:description" content="Buy kids sunglasses, ski goggles &amp; screen glasses with UV400 protection. Toddler to teen. Free EU shipping over €69.">
  <meta name="twitter:image" content="https://olivioandco.eu/cdn/shop/files/catalog-og-image.jpg?width=1200&height=630">

  <!-- SEO: Performance — DNS prefetch & preconnect -->
  <link rel="dns-prefetch" href="https://cdn.shopify.com">
  <link rel="dns-prefetch" href="https://olivioandco.eu">
  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

  <!-- SEO: Verification Tags -->
  <meta name="google-site-verification" content="h-rzQ2Y5KNPvrhrSGr0-ChWcJwSg4QSTZBtAs7PghJk">
  <meta name="facebook-domain-verification" content="7j0pgoyy1kqm0valfjti8lokli9wtg">

  <!-- SEO: Structured Data (Schema.org CollectionPage) -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Luxury Sunglasses & Eyewear Catalog",
    "description": "Interactive 3D product catalog featuring premium sunglasses and eyewear with detailed specifications, real-time filters, and polarised lens options.",
    "url": "https://olivioandco.eu/products/catalog",
    "isPartOf": {
      "@type": "WebSite",
      "name": "Olivio&Co Store",
      "url": "https://olivioandco.eu"
    },
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home",     "item": "https://olivioandco.eu" },
        { "@type": "ListItem", "position": 2, "name": "Products", "item": "https://olivioandco.eu/collections/all-sunglasses" },
        { "@type": "ListItem", "position": 3, "name": "Catalog",  "item": "https://olivioandco.eu/products/catalog" }
      ]
    }
  }
  </script>

  <!-- SEO: Organization Schema — brand trust + logo + contact -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Olivio & Co",
    "url": "https://olivioandco.eu",
    "logo": "https://olivioandco.eu/cdn/shop/files/OLIVIO_CO_logo.png",
    "sameAs": [
      "https://www.instagram.com/olivioandco",
      "https://www.facebook.com/olivioandco"
    ],
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+33189708198",
      "email": "e_service_eu@olivioandco.com",
      "contactType": "customer service",
      "availableLanguage": ["English", "French"]
    },
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "231 rue Saint-Honoré",
      "addressLocality": "Paris",
      "addressCountry": "FR"
    }
  }
  </script>

  <!-- SEO: WebSite + SearchAction Schema — Sitelinks Search Box -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Olivio & Co",
    "url": "https://olivioandco.eu",
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "https://olivioandco.eu/search?q={search_term_string}"
      },
      "query-input": "required name=search_term_string"
    }
  }
  </script>

  <!-- SEO: ItemList Schema — catalog overview for Google -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Kids Sunglasses & Eyewear Catalog — Olivio & Co",
    "description": "Premium UV400 sunglasses for children — toddler, kids, junior and teen eyewear including polarised lenses, ski goggles and screen glasses.",
    "url": "https://olivioandco.eu/products/catalog",
    "numberOfItems": 155
  }
  </script>

  <!-- SEO: FAQPage Schema — rich snippets in Google search results -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What age do kids need sunglasses?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Children need UV400 sunglasses from birth. Olivio & Co covers every age: Baby (0–12m), Toddler (1–3y), Kids (3–6y), Junior (6–10y), Junior+ (10–12y), Teen & Adult (12+). Children's eyes transmit 70% more UV radiation than adult eyes, making protection essential."
        }
      },
      {
        "@type": "Question",
        "name": "Do Olivio & Co sunglasses have UV400 protection?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. All Olivio & Co sunglasses, sport sunglasses and ski goggles provide 100% UV400 protection, blocking all UVA and UVB radiation. Frames are BPA-free and designed for active children."
        }
      },
      {
        "@type": "Question",
        "name": "What size sunglasses does my child need?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Baby (0–12m): head 40–44 cm | Toddler (1–3y): 44–48 cm | Kids (3–6y): 48–51 cm | Junior (6–10y): 51–54 cm | Junior+ (10–12y): 54–56 cm | Teen & Adult (12+): 56+ cm. Measure around the widest part of the head above the ears."
        }
      },
      {
        "@type": "Question",
        "name": "What is the free shipping threshold?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Free shipping on all orders over €69, delivered across Europe. Orders ship within 1–2 business days from Paris, France."
        }
      },
      {
        "@type": "Question",
        "name": "Do kids need ski goggles for the slopes?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. UV radiation is up to 40% stronger at altitude and reflected snow multiplies exposure further. Olivio & Co junior ski goggles provide 100% UV400 protection with anti-fog lenses and full-face wind coverage — the only kids eyewear brand offering a dedicated ski goggle range."
        }
      }
    ]
  }
  </script>

  {{ content_for_header }}

  {{ 'catalog.css' | asset_url | stylesheet_tag }}
</head>
<body>

{{ content_for_layout }}

</body>
</html>
