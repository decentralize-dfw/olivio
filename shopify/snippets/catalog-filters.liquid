<!-- Filter popup (opens upward) -->
<div id="filter-popup">

  <!-- Age -->
  <div class="fp-row">
    <span class="fp-label">Age</span>
    <div class="fp-btns">
      <button class="fp-btn" data-cat="age" data-val="Baby">Baby</button>
      <button class="fp-btn" data-cat="age" data-val="Toddler">Toddler</button>
      <button class="fp-btn" data-cat="age" data-val="Kids">Kids</button>
      <button class="fp-btn" data-cat="age" data-val="Junior">Junior</button>
      <button class="fp-btn" data-cat="age" data-val="Junior+">Junior+</button>
      <button class="fp-btn" data-cat="age" data-val="Teen &amp; Adult">Teen &amp; Adult</button>
    </div>
  </div>

  <!-- Type -->
  <div class="fp-row">
    <span class="fp-label">Type</span>
    <div class="fp-btns">
      <button class="fp-btn" data-cat="type" data-val="Sunglasses" title="Kids Sunglasses UV400">☀ Sun</button>
      <button class="fp-btn" data-cat="type" data-val="Sports Sunglasses" title="Sport Sunglasses for Children">⚡ Sport</button>
      <button class="fp-btn" data-cat="type" data-val="Ski Goggles" title="Kids Ski Goggles UV400">⛷ Ski</button>
      <button class="fp-btn" data-cat="type" data-val="Screen Glasses" title="Blue Light Screen Glasses for Kids">🖥 Screen</button>
      <button class="fp-btn" data-cat="type" data-val="Accessories">✦ Acc</button>
    </div>
  </div>

  <!-- Shape -->
  <div class="fp-row">
    <span class="fp-label">Shape</span>
    <div class="fp-btns">
      <button class="fp-btn shape-btn" data-cat="shape" data-val="Oval" title="Oval">
        <svg width="22" height="14" viewBox="0 0 22 14" fill="none">
          <ellipse cx="11" cy="7" rx="10" ry="6" stroke="currentColor" stroke-width="1.8"/>
        </svg>
      </button>
      <button class="fp-btn shape-btn" data-cat="shape" data-val="Round" title="Round">
        <svg width="15" height="15" viewBox="0 0 15 15" fill="none">
          <circle cx="7.5" cy="7.5" r="6.5" stroke="currentColor" stroke-width="1.8"/>
        </svg>
      </button>
      <button class="fp-btn shape-btn" data-cat="shape" data-val="D-Frame" title="D-Frame (#D)">
        <svg width="16" height="15" viewBox="0 0 16 15" fill="none">
          <polygon points="8,1 15,4 15,11 8,14 1,11 1,4" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" fill="none"/>
        </svg>
      </button>
      <button class="fp-btn shape-btn" data-cat="shape" data-val="Shield" title="Creative Shield">
        <svg width="14" height="17" viewBox="0 0 14 17" fill="none">
          <path d="M7 1.5L13 4.5v5.5Q13 14.5 7 15.5Q1 14.5 1 10V4.5Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
        </svg>
      </button>
      <button class="fp-btn shape-btn" data-cat="shape" data-val="Full-Rim" title="Full-Rim">
        <svg width="20" height="14" viewBox="0 0 20 14" fill="none">
          <rect x="1" y="1" width="18" height="12" rx="3" stroke="currentColor" stroke-width="1.8"/>
        </svg>
      </button>
      <button class="fp-btn shape-btn" data-cat="shape" data-val="Half-Rim" title="Half-Rim">
        <svg width="20" height="11" viewBox="0 0 20 11" fill="none">
          <path d="M1 10 Q1 1 10 1 Q19 1 19 10" stroke="currentColor" stroke-width="1.8"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Lens -->
  <div class="fp-row">
    <span class="fp-label">Lens</span>
    <div class="fp-btns">
      <button class="fp-btn" data-cat="lens" data-val="Polarised" title="Polarised UV400 Sunglasses">
        <svg width="13" height="13" viewBox="0 0 13 13" fill="none">
          <circle cx="6.5" cy="6.5" r="5.5" stroke="currentColor" stroke-width="1.4"/>
          <line x1="1" y1="6.5" x2="12" y2="6.5" stroke="currentColor" stroke-width="1.3"/>
          <line x1="2" y1="4.5" x2="11" y2="4.5" stroke="currentColor" stroke-width="0.8" opacity="0.5"/>
          <line x1="2" y1="8.5" x2="11" y2="8.5" stroke="currentColor" stroke-width="0.8" opacity="0.5"/>
        </svg>
        Polar
      </button>
      <button class="fp-btn" data-cat="lens" data-val="Non-Polarised">
        <svg width="13" height="13" viewBox="0 0 13 13" fill="none">
          <circle cx="6.5" cy="6.5" r="5.5" stroke="currentColor" stroke-width="1.4"/>
        </svg>
        Non-P
      </button>
      <button class="fp-btn" data-cat="lens" data-val="__other__">Other</button>
    </div>
  </div>

  <!-- Stock -->
  <div class="fp-row">
    <span class="fp-label">Stock</span>
    <div class="fp-btns">
      <button class="fp-btn" data-cat="stock" data-val="in">✓ In Stock</button>
    </div>
  </div>

  <!-- Collection -->
  <div class="fp-row">
    <span class="fp-label">Pick</span>
    <div class="fp-btns">
      <button class="fp-btn" data-cat="collection" data-val="featured">★ Featured</button>
      <button class="fp-btn" data-cat="collection" data-val="bestseller">🔥 Best Seller</button>
    </div>
  </div>

  <div class="fp-divider"></div>
  <button class="fp-reset" id="filter-reset-btn">↺ Reset all filters</button>
</div>
