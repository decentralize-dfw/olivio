<!-- ── Welcome Popup ───────────────────────────────── -->
<div id="welcome-overlay">
  <div id="welcome-box">
    <button id="welcome-close" aria-label="Close">✕</button>

    <!-- Step 1: Region -->
    <div class="wp-step active" id="wp-step1">
      <div class="wp-eyebrow">Olivio&amp;Co</div>
      <div class="wp-title">Select your region</div>
      <div class="wp-sub">We'll show you prices and shipping options for your area.</div>
      <div class="wp-regions">
        <button class="wp-region" data-region="com" type="button">
          <img src="https://cdn.shopify.com/s/files/1/0804/6411/8043/files/us.png?v=1728910229" alt="US flag">
          <span>United States</span>
        </button>
        <button class="wp-region selected" data-region="eu" type="button">
          <img src="https://cdn.shopify.com/s/files/1/0804/6411/8043/files/europe.png?v=1728910229" alt="Europe flag">
          <span>Europe</span>
        </button>
      </div>
      <button class="wp-btn" id="wp-continue">Continue →</button>
    </div>

    <!-- Step 2: Discount -->
    <div class="wp-step" id="wp-step2">
      <div class="wp-eyebrow">Welcome gift</div>
      <div class="wp-discount-badge">10% OFF</div>
      <div class="wp-title">Your first order</div>
      <div class="wp-sub">Subscribe to our newsletter and get 10% off your first purchase.</div>
      <input class="wp-email" type="email" id="wp-email" placeholder="your@email.com" autocomplete="email">
      <button class="wp-btn" id="wp-claim">Claim 10% Off</button>
      <button class="wp-skip" id="wp-skip">No thanks, continue without discount</button>
    </div>
  </div>
</div>
